# Local stack config. Copy to `.env` before `docker compose up`.

# WAHA Plus API key. Any non-empty string is fine for local testing —
# it's only used between the two containers on your laptop.
WAHA_API_KEY=local-waha-key-change-me

# Invite code required to sign up. Keep `local-dev` for testing.
INVITE_CODE=local-dev

# Public URL the signup page hands to users. Default is fine for Claude
# Code and Claude Desktop. For Claude.ai web (which can't reach localhost),
# replace with the URL of a cloudflared / ngrok tunnel pointing at :8080.
# PUBLIC_BASE_URL=https://<your-tunnel>.trycloudflare.com
